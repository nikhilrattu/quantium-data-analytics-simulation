      <column caption='PY Year' datatype='integer' name='[Calculation_2464846757376004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1]-1' />
      </column>
      <column caption='CY Sales' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_2464846757785605]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([DATE])=[Parameters].[Parameter 1] THEN [TOT_SALES]&#13;&#10;END' />
      </column>
      <column caption='PY Sales' datatype='real' name='[Calculation_2464846758846470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([DATE])=[Parameters].[Parameter 1]-1 THEN [TOT_SALES]&#13;&#10;END' />
      </column>
      <column caption='% DIff Sales' datatype='real' default-format='p0.00%' name='[Calculation_2464846759014407]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_2464846757785605])-SUM([Calculation_2464846758846470]))/SUM([Calculation_2464846758846470])' />
      </column>
      <column caption='Tot Trans' datatype='integer' name='[Calculation_2464846761619464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([TXN_ID])' />
      </column>
      <column caption='Avg basket value' datatype='real' name='[Calculation_2464846762565641]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TOT_SALES])/COUNT([TXN_ID])' />
      </column>
      <column caption='Avg unit per trans' datatype='real' name='[Calculation_2464846764138506]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([PROD_QTY])/COUNT([TXN_ID])' />
      </column>
      <column caption='Top 6 by revenue' datatype='string' name='[Calculation_2464846770012171]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [BRAND] = &quot;KETTLE&quot; OR [BRAND] = &quot;DORITOS&quot; OR [BRAND] = &quot;SMITHS&quot;&#13;&#10;OR [BRAND] = &quot;PRINGLES&quot; OR [BRAND] = &quot;INFUZIONS&quot; OR [BRAND] = &quot;THINS&quot;&#13;&#10;THEN [BRAND] ELSE &quot;Other&quot; END' />
